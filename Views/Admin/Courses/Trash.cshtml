@model List<TrungTamNgoaiNgu.Models.KhoaHoc>
@{
    ViewData["Title"] = "Thùng rác — Khóa học";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-courses.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-trash3 kh-trash-icon"></i> Thùng rác khóa học</div>
        <div class="page-sub">@Model.Count khóa học đã bị xóa — có thể khôi phục lại</div>
    </div>
    <a asp-action="Index" class="btn btn-outline">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<div class="card">
    <div class="table-wrap">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-trash3 kh-empty-ok"></i>
                <p>Thùng rác trống! Không có khóa học nào bị xóa.</p>
            </div>
        }
        else
        {
            <div class="kh-bulk-row in-card">
                <form id="bulkRestoreForm" method="post" asp-action="bulkrestore" class="kh-bulk-controls"
                      onsubmit="return confirmBulkRestore()">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-sm">
                        <i class="bi bi-arrow-counterclockwise"></i> Khôi phục đã chọn
                    </button>
                </form>
                <div id="selectedRestoreCount" class="kh-selected-count">Đã chọn: 0</div>
            </div>

            <table>
                <thead>
                    <tr>
                        <th class="kh-check-col">
                            <input id="checkAllTrash" type="checkbox" class="kh-check" />
                        </th>
                        <th>#</th>
                        <th>Ảnh</th>
                        <th>Tên khóa học</th>
                        <th>Danh mục</th>
                        <th>Trạng thái</th>
                        <th>Ngày xóa</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var kh = Model[i];
                        <tr class="kh-trash-row">
                            <td class="kh-check-col">
                                <input type="checkbox" name="selectedIds" value="@kh.KhoaHocId"
                                       class="kh-check kh-select-trash-item" form="bulkRestoreForm" />
                            </td>
                            <td class="kh-col-index">@(i + 1)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(kh.AnhKhoaHoc))
                                {
                                    <img src="@kh.AnhKhoaHoc" class="kh-trash-thumb" />
                                }
                                else
                                {
                                    <div class="kh-trash-thumb-empty">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="kh-trash-name">@kh.TenKhoaHoc</div>
                                <div class="kh-slug">@kh.Slug</div>
                            </td>
                            <td>
                                @if (kh.DanhMuc != null)
                                { <span class="badge badge-gray">@kh.DanhMuc.TenDanhMuc</span> }
                                else { <span class="kh-muted">—</span> }
                            </td>
                            <td>
                                @if (kh.TrangThai == 0) { <span class="badge badge-warning">Tạm ngưng</span> }
                                else { <span class="badge badge-success">Đang hoạt động</span> }
                            </td>
                            <td class="kh-trash-time">
                                <i class="bi bi-clock-history"></i>
                                @(kh.DeletedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                            </td>
                            <td>
                                <form method="post" asp-action="restore" asp-route-id="@kh.KhoaHocId"
                                      class="kh-inline-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success btn-sm" title="Khôi phục">
                                        <i class="bi bi-arrow-counterclockwise"></i> Khôi phục
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
    <script>
        const checkAllTrash = document.getElementById('checkAllTrash');
        const trashItems = Array.from(document.querySelectorAll('.kh-select-trash-item'));
        const selectedRestoreCount = document.getElementById('selectedRestoreCount');

        function updateTrashCount() {
            if (!selectedRestoreCount) return;
            const count = trashItems.filter(x => x.checked).length;
            selectedRestoreCount.textContent = `Đã chọn: ${count}`;

            if (checkAllTrash) {
                checkAllTrash.checked = count > 0 && count === trashItems.length;
                checkAllTrash.indeterminate = count > 0 && count < trashItems.length;
            }
        }

        if (checkAllTrash) {
            checkAllTrash.addEventListener('change', () => {
                trashItems.forEach(x => x.checked = checkAllTrash.checked);
                updateTrashCount();
            });
        }
        trashItems.forEach(x => x.addEventListener('change', updateTrashCount));
        updateTrashCount();

        function confirmBulkRestore() {
            const count = trashItems.filter(x => x.checked).length;
            if (count === 0) {
                alert('Vui lòng chọn ít nhất một khóa học để khôi phục.');
                return false;
            }
            return confirm(`Xác nhận khôi phục ${count} khóa học đã chọn?`);
        }
    </script>
}
