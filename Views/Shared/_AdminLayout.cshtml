<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Five Genius Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css?v=3" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@{
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool inDaoTao   = ctrl is "Courses" or "CourseCategories" or "LopHoc";
    bool inNhanSu   = ctrl is "HocVien" or "GiaoVien";
    bool inTaiChinh = ctrl is "HoaDon" or "Luong";
    bool inHeThong  = ctrl is "CoSo" or "ThongBao" or "AuditLogs";
}

<!-- ═══════════ SIDEBAR ═══════════ -->
<aside id="sidebar">

    <!-- Brand -->
    <a class="sb-brand" href="/Admin/Dashboard">
        <div class="sb-logo">🎓</div>
        <div class="sb-brand-text">
            <div class="t1">Five Genius</div>
            <div class="t2">Academy Management</div>
        </div>
    </a>

    <!-- Nav -->
    <nav class="sb-nav">

        <!-- Dashboard -->
        <a class="sb-direct @(ctrl == "Dashboard" ? "active" : "")"
           asp-controller="Dashboard" asp-action="Index" asp-route-area="">
            <span class="ico"><i class="bi bi-grid-1x2-fill"></i></span>
            <span class="lbl">Tổng quan</span>
        </a>

        <div class="sb-div"></div>

        <!-- ── Nhóm: Đào tạo ── -->
        <div class="sb-group">
            <button class="sb-group-btn @(inDaoTao ? "has-active" : "")" data-target="g-daotao">
                <span class="ico" style="background:rgba(99,102,241,.12);color:#a5b4fc"><i class="bi bi-journal-richtext"></i></span>
                <span class="lbl">Đào tạo</span>
                <i class="bi bi-chevron-right arrow"></i>
            </button>
            <div class="sb-items @(inDaoTao ? "open" : "")" id="g-daotao">
                <a class="sb-item @(ctrl == "CourseCategories" ? "active" : "")"
                   asp-controller="CourseCategories" asp-action="Index" asp-route-area="">Danh mục khóa học</a>
                <a class="sb-item @(ctrl == "Courses" ? "active" : "")"
                   asp-controller="Courses" asp-action="Index" asp-route-area="">Khóa học</a>
                <a class="sb-item @(ctrl == "LopHoc" ? "active" : "")"
                   asp-controller="LopHoc" asp-action="Index" asp-route-area="">Lớp học</a>
            </div>
        </div>

        <!-- ── Nhóm: Nhân sự ── -->
        <div class="sb-group">
            <button class="sb-group-btn @(inNhanSu ? "has-active" : "")" data-target="g-nhansu">
                <span class="ico" style="background:rgba(16,185,129,.12);color:#6ee7b7"><i class="bi bi-people-fill"></i></span>
                <span class="lbl">Nhân sự</span>
                <i class="bi bi-chevron-right arrow"></i>
            </button>
            <div class="sb-items @(inNhanSu ? "open" : "")" id="g-nhansu">
                <a class="sb-item @(ctrl == "HocVien" ? "active" : "")"
                   asp-controller="HocVien" asp-action="Index" asp-route-area="">Học viên</a>
                <a class="sb-item @(ctrl == "GiaoVien" ? "active" : "")"
                   asp-controller="GiaoVien" asp-action="Index" asp-route-area="">Giáo viên</a>
                <a class="sb-item @(ctrl == "NhanVien" ? "active" : "")"
                   asp-controller="NhanVien" asp-action="Index" asp-route-area="">Nhân viên</a>
            </div>
        </div>

        <!-- ── Nhóm: Tài chính ── -->
        <div class="sb-group">
            <button class="sb-group-btn @(inTaiChinh ? "has-active" : "")" data-target="g-taichinh">
                <span class="ico" style="background:rgba(245,158,11,.12);color:#fcd34d"><i class="bi bi-cash-stack"></i></span>
                <span class="lbl">Tài chính</span>
                <i class="bi bi-chevron-right arrow"></i>
            </button>
            <div class="sb-items @(inTaiChinh ? "open" : "")" id="g-taichinh">
                <a class="sb-item @(ctrl == "HoaDon" ? "active" : "")"
                   asp-controller="HoaDon" asp-action="Index" asp-route-area="">Hóa đơn</a>
                <a class="sb-item @(ctrl == "Luong" ? "active" : "")"
                   asp-controller="Luong" asp-action="Index" asp-route-area="">Bảng lương</a>
                <a class="sb-item @(ctrl == "PhieuThu" ? "active" : "")"
                   asp-controller="PhieuThu" asp-action="Index" asp-route-area="">Phiếu thu</a>
            </div>
        </div>

        <!-- ── Nhóm: Hệ thống ── -->
        <div class="sb-group">
            <button class="sb-group-btn @(inHeThong ? "has-active" : "")" data-target="g-hethong">
                <span class="ico" style="background:rgba(107,114,128,.15);color:#9ca3af"><i class="bi bi-gear-fill"></i></span>
                <span class="lbl">Hệ thống</span>
                <i class="bi bi-chevron-right arrow"></i>
            </button>
            <div class="sb-items @(inHeThong ? "open" : "")" id="g-hethong">
                <a class="sb-item @(ctrl == "CoSo" ? "active" : "")"
                   asp-controller="CoSo" asp-action="Index" asp-route-area="">Cơ sở đào tạo</a>
                <a class="sb-item @(ctrl == "ThongBao" ? "active" : "")"
                   asp-controller="ThongBao" asp-action="Index" asp-route-area="">Thông báo</a>
                <a class="sb-item @(ctrl == "AuditLogs" ? "active" : "")"
                   asp-controller="AuditLogs" asp-action="Index" asp-route-area="">Nhật ký hệ thống</a>
                <a class="sb-item" href="/" target="_blank">Xem trang web ↗</a>
            </div>
        </div>

    </nav>

    <!-- User footer -->
    <div class="sb-footer">
        <div class="av sm">LH</div>
        <div class="sb-foot-info">
            <div class="n">Lê Văn Hậu</div>
            <div class="r">Quản trị viên</div>
        </div>
    </div>

</aside>

<!-- ═══════════ MAIN ═══════════ -->
<div class="main-wrap" id="mainWrap">

    <!-- Topbar -->
    <header class="topbar">
        <button class="icon-btn top-toggle" id="sbToggle" title="Thu/mở sidebar">
            <i class="bi bi-list" style="font-size:1.2rem"></i>
        </button>

        <nav class="top-bc">
            <i class="bi bi-house" style="font-size:.8rem"></i>
            <span class="sep">›</span>
            <span>Admin</span>
            <span class="sep">›</span>
            <span class="cur">@(ViewData["Title"] ?? "Dashboard")</span>
        </nav>

        <div class="top-right">
            @if (TempData["ThanhCong"] != null)
            {
                <div class="toast ok"><i class="bi bi-check-circle-fill"></i> @TempData["ThanhCong"]</div>
            }
            @if (TempData["LoiXay"] != null)
            {
                <div class="toast err"><i class="bi bi-exclamation-circle-fill"></i> @TempData["LoiXay"]</div>
            }
            <button class="icon-btn" title="Thông báo" style="position:relative">
                <i class="bi bi-bell"></i>
                <span class="badge-dot"></span>
            </button>
            <button class="icon-btn" title="Cài đặt">
                <i class="bi bi-gear"></i>
            </button>
            <div class="av" title="Tài khoản của tôi">LH</div>
        </div>
    </header>

    <!-- Content -->
    <main class="page-main">
        @RenderBody()
    </main>

    <footer class="page-foot">
        Five Genius Academy &copy; 2026 &mdash; Xây dựng với ASP.NET Core 10 &amp; EF Core
    </footer>
</div>

<script>
/* ── Sidebar toggle ─────────────────────────── */
const sb  = document.getElementById('sidebar');
const mw  = document.getElementById('mainWrap');
document.getElementById('sbToggle').addEventListener('click', () => {
    sb.classList.toggle('mini');
    mw.classList.toggle('mini');
});

/* ── Accordion groups ───────────────────────── */
document.querySelectorAll('.sb-group-btn').forEach(btn => {
    // Sync arrow state on page load for open groups
    const panel = document.getElementById(btn.dataset.target);
    if (panel && panel.classList.contains('open')) {
        btn.classList.add('open');
    }

    btn.addEventListener('click', () => {
        const isOpen = panel.classList.contains('open');

        // Close all panels
        document.querySelectorAll('.sb-items').forEach(p => p.classList.remove('open'));
        document.querySelectorAll('.sb-group-btn').forEach(b => b.classList.remove('open'));

        // Toggle clicked panel
        if (!isOpen) {
            panel.classList.add('open');
            btn.classList.add('open');
        }
    });
});
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
