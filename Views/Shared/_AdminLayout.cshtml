<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Five Genius Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>

<!-- ===== SIDEBAR ===== -->
<aside id="sidebar">
    <div class="sidebar-brand">
        <span class="brand-icon">🎓</span>
        <span class="brand-text">Five Genius</span>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section-label">TỔNG QUAN</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
           asp-controller="Dashboard" asp-action="Index" asp-route-area="">
            <i class="bi bi-grid-1x2-fill"></i> Dashboard
        </a>

        <div class="nav-section-label">QUẢN LÝ</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DanhMuc" ? "active" : "")"
           asp-controller="DanhMuc" asp-action="Index" asp-route-area="">
            <i class="bi bi-tags-fill"></i> Danh mục
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "KhoaHoc" ? "active" : "")"
           asp-controller="KhoaHoc" asp-action="Index" asp-route-area="">
            <i class="bi bi-journal-richtext"></i> Khóa học
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "LopHoc" ? "active" : "")"
           asp-controller="LopHoc" asp-action="Index" asp-route-area="">
            <i class="bi bi-people-fill"></i> Lớp học
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "HocVien" ? "active" : "")"
           asp-controller="HocVien" asp-action="Index" asp-route-area="">
            <i class="bi bi-person-badge-fill"></i> Học viên
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "GiaoVien" ? "active" : "")"
           asp-controller="GiaoVien" asp-action="Index" asp-route-area="">
            <i class="bi bi-mortarboard-fill"></i> Giáo viên
        </a>

        <div class="nav-section-label">TÀI CHÍNH</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "HoaDon" ? "active" : "")"
           asp-controller="HoaDon" asp-action="Index" asp-route-area="">
            <i class="bi bi-receipt-cutoff"></i> Hóa đơn
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Luong" ? "active" : "")"
           asp-controller="Luong" asp-action="Index" asp-route-area="">
            <i class="bi bi-cash-coin"></i> Bảng lương
        </a>

        <div class="nav-section-label">HỆ THỐNG</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ThongBao" ? "active" : "")"
           asp-controller="ThongBao" asp-action="Index" asp-route-area="">
            <i class="bi bi-bell-fill"></i> Thông báo
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "CoSo" ? "active" : "")"
           asp-controller="CoSo" asp-action="Index" asp-route-area="">
            <i class="bi bi-building-fill"></i> Cơ sở
        </a>
        <a class="nav-link" href="/">
            <i class="bi bi-globe2"></i> Xem trang web
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="avatar-circle">LH</div>
        <div>
            <div class="sidebar-user-name">Admin</div>
            <div class="sidebar-user-role">Quản trị viên</div>
        </div>
    </div>
</aside>

<!-- ===== MAIN CONTENT ===== -->
<div class="main-wrapper">

    <!-- Topbar -->
    <header class="topbar">
        <button id="sidebarToggle" class="btn-icon" title="Menu">
            <i class="bi bi-list"></i>
        </button>

        <div class="topbar-breadcrumb">
            <span class="text-muted">Admin</span>
            <i class="bi bi-chevron-right text-muted mx-1" style="font-size:.75rem"></i>
            <span>@(ViewData["Title"] ?? "Dashboard")</span>
        </div>

        <div class="topbar-actions ms-auto">
            @if (TempData["ThanhCong"] != null)
            {
                <span class="badge bg-success">✓ @TempData["ThanhCong"]</span>
            }
            @if (TempData["LoiXay"] != null)
            {
                <span class="badge bg-danger">✗ @TempData["LoiXay"]</span>
            }
            <button class="btn-icon" title="Thông báo">
                <i class="bi bi-bell"></i>
            </button>
            <div class="avatar-circle sm">LH</div>
        </div>
    </header>

    <!-- Page Content -->
    <main class="page-content">
        @RenderBody()
    </main>

    <footer class="page-footer">
        Five Genius Academy &copy; 2026 — ASP.NET Core 10 &amp; EF Core
    </footer>
</div>

<script>
    document.getElementById('sidebarToggle').addEventListener('click', () => {
        document.getElementById('sidebar').classList.toggle('collapsed');
        document.querySelector('.main-wrapper').classList.toggle('expanded');
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
