@model List<TrungTamNgoaiNgu.Models.DanhMucKhoaHoc>
@{
    ViewData["Title"] = "Thùng rác — Danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-trash3" style="color:var(--red)"></i> Thùng rác danh mục</div>
        <div class="page-sub">@Model.Count danh mục đã bị xóa — có thể khôi phục lại</div>
    </div>
    <a asp-action="Index" class="btn btn-outline">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<div class="card">
    <div class="table-wrap">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-trash3" style="color:var(--green)"></i>
                <p>Thùng rác trống! Không có danh mục nào bị xóa.</p>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tên danh mục</th>
                        <th>Slug</th>
                        <th>Mô tả</th>
                        <th>Ngày xóa</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var dm = Model[i];
                        <tr style="opacity:.85">
                            <td style="color:var(--muted); font-size:.8rem">@(i + 1)</td>
                            <td>
                                <div style="font-weight:500; text-decoration:line-through; color:var(--muted)">
                                    @dm.TenDanhMuc
                                </div>
                            </td>
                            <td>
                                <code style="font-size:.75rem; background:#f3f4f6; padding:2px 7px;
                                             border-radius:5px; color:#9ca3af">@dm.Slug</code>
                            </td>
                            <td style="font-size:.82rem; color:var(--muted); max-width:180px;
                                       overflow:hidden; white-space:nowrap; text-overflow:ellipsis">
                                @(string.IsNullOrEmpty(dm.MoTa) ? "—" : dm.MoTa)
                            </td>
                            <td style="font-size:.8rem; color:var(--red)">
                                <i class="bi bi-clock-history"></i>
                                @(dm.DeletedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                            </td>
                            <td>
                                <form method="post" asp-action="restore" asp-route-id="@dm.DanhMucId"
                                      style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success btn-sm" title="Khôi phục">
                                        <i class="bi bi-arrow-counterclockwise"></i> Khôi phục
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
