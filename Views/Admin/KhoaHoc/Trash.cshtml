@model List<TrungTamNgoaiNgu.Models.KhoaHoc>
@{
    ViewData["Title"] = "Thùng rác — Khóa học";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title"><i class="bi bi-trash3" style="color:var(--red)"></i> Thùng rác khóa học</div>
        <div class="page-sub">@Model.Count khóa học đã bị xóa — có thể khôi phục lại</div>
    </div>
    <a asp-action="Index" class="btn btn-outline">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<div class="card">
    <div class="table-wrap">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-trash3" style="color:var(--green)"></i>
                <p>Thùng rác trống! Không có khóa học nào bị xóa.</p>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Ảnh</th>
                        <th>Tên khóa học</th>
                        <th>Danh mục</th>
                        <th>Trạng thái</th>
                        <th>Ngày xóa</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var kh = Model[i];
                        <tr style="opacity:.85">
                            <td style="color:var(--muted); font-size:.8rem">@(i + 1)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(kh.AnhKhoaHoc))
                                {
                                    <img src="@kh.AnhKhoaHoc"
                                         style="width:56px; height:38px; object-fit:cover; border-radius:6px; filter:grayscale(30%); border:1px solid var(--border)" />
                                }
                                else
                                {
                                    <div style="width:56px; height:38px; background:#f3f4f6; border-radius:6px;
                                                display:flex; align-items:center; justify-content:center; color:#9ca3af">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div style="font-weight:500; text-decoration:line-through; color:var(--muted)">@kh.TenKhoaHoc</div>
                                <div style="font-size:.74rem; color:var(--muted)">@kh.Slug</div>
                            </td>
                            <td>
                                @if (kh.DanhMuc != null)
                                { <span class="badge badge-gray">@kh.DanhMuc.TenDanhMuc</span> }
                                else { <span style="color:var(--muted)">—</span> }
                            </td>
                            <td>
                                @if (kh.TrangThai == 1) { <span class="badge badge-success">Đang mở</span> }
                                else if (kh.TrangThai == 2) { <span class="badge badge-warning">Sắp khai giảng</span> }
                                else { <span class="badge badge-danger">Đã đóng</span> }
                            </td>
                            <td style="font-size:.8rem; color:var(--red)">
                                <i class="bi bi-clock-history"></i>
                                @(kh.DeletedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                            </td>
                            <td>
                                <form method="post" asp-action="restore" asp-route-id="@kh.KhoaHocId"
                                      style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success btn-sm" title="Khôi phục">
                                        <i class="bi bi-arrow-counterclockwise"></i> Khôi phục
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
