@model TrungTamNgoaiNgu.Models.KhoaHoc
@{
    ViewData["Title"] = "Thêm khóa học";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">Thêm khóa học mới</div>
        <div class="page-sub">Điền đầy đủ thông tin bên dưới rồi nhấn Lưu</div>
    </div>
    <a asp-action="Index" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div style="display:grid; grid-template-columns:1fr 340px; gap:20px; align-items:start">

        <!-- ── Cột trái: thông tin ── -->
        <div style="display:flex; flex-direction:column; gap:16px">

            <div class="card">
                <div class="card-header"><i class="bi bi-info-circle"></i> Thông tin cơ bản</div>
                <div class="card-body" style="display:flex; flex-direction:column; gap:14px">

                    <div class="form-group">
                        <label asp-for="TenKhoaHoc">Tên khóa học <span style="color:var(--red)">*</span></label>
                        <input asp-for="TenKhoaHoc" class="form-control" placeholder="VD: IELTS Intensive 7.0+" />
                        <span asp-validation-for="TenKhoaHoc" class="text-danger"></span>
                    </div>

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px">
                        <div class="form-group">
                            <label asp-for="DanhMucId">Danh mục <span style="color:var(--red)">*</span></label>
                            <select asp-for="DanhMucId" class="form-control">
                                <option value="">-- Chọn danh mục --</option>
                                @foreach (var dm in (List<TrungTamNgoaiNgu.Models.DanhMucKhoaHoc>)ViewBag.DanhMucs)
                                {
                                    <option value="@dm.DanhMucId">@dm.TenDanhMuc</option>
                                }
                            </select>
                            <span asp-validation-for="DanhMucId" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="TrangThai">Trạng thái</label>
                            <select asp-for="TrangThai" class="form-control">
                                <option value="1">✅ Đang mở</option>
                                <option value="2">🔜 Sắp khai giảng</option>
                                <option value="0">❌ Đã đóng</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="MoTa">Mô tả ngắn</label>
                        <textarea asp-for="MoTa" class="form-control" rows="3"
                                  placeholder="Giới thiệu ngắn về khóa học..."></textarea>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><i class="bi bi-list-check"></i> Chi tiết chương trình</div>
                <div class="card-body" style="display:flex; flex-direction:column; gap:14px">
                    <div class="form-group">
                        <label asp-for="DoiTuong">Đối tượng học viên</label>
                        <input asp-for="DoiTuong" class="form-control"
                               placeholder="VD: Học sinh cấp 3, người đi làm muốn lấy chứng chỉ..." />
                    </div>
                    <div class="form-group">
                        <label asp-for="KetQuaDatDuoc">Kết quả đạt được</label>
                        <textarea asp-for="KetQuaDatDuoc" class="form-control" rows="3"
                                  placeholder="Sau khi hoàn thành, học viên sẽ..."></textarea>
                    </div>
                    <div class="form-group">
                        <label asp-for="YeuCauDauVao">Yêu cầu đầu vào</label>
                        <input asp-for="YeuCauDauVao" class="form-control"
                               placeholder="VD: Tiếng Anh cơ bản B1, đã thi thử IELTS..." />
                    </div>
                </div>
            </div>

        </div>

        <!-- ── Cột phải: ảnh + nút lưu ── -->
        <div style="display:flex; flex-direction:column; gap:16px">

            <div class="card">
                <div class="card-header"><i class="bi bi-image"></i> Ảnh khóa học</div>
                <div class="card-body">
                    <!-- Preview -->
                    <div id="imgPreviewWrap" style="width:100%; aspect-ratio:16/9; border-radius:10px;
                         border:2px dashed var(--border); overflow:hidden; margin-bottom:12px;
                         display:flex; align-items:center; justify-content:center;
                         background:#f9fafb; cursor:pointer; transition:border-color .2s"
                         onclick="document.getElementById('anhFile').click()"
                         ondragover="event.preventDefault(); this.style.borderColor='var(--brand)'"
                         ondragleave="this.style.borderColor='var(--border)'"
                         ondrop="handleDrop(event)">
                        <img id="imgPreview" src="#" alt="preview"
                             style="width:100%; height:100%; object-fit:cover; display:none" />
                        <div id="imgPlaceholder" style="text-align:center; color:var(--muted)">
                            <i class="bi bi-cloud-upload" style="font-size:2.2rem; display:block; margin-bottom:8px; opacity:.5"></i>
                            <div style="font-size:.82rem; font-weight:500">Nhấp hoặc kéo thả ảnh vào đây</div>
                            <div style="font-size:.75rem; margin-top:4px">JPG, PNG, WEBP • Tối đa 5MB</div>
                        </div>
                    </div>

                    <input type="file" id="anhFile" name="anhFile" accept="image/*"
                           style="display:none" onchange="previewImg(this)" />

                    <button type="button" class="btn btn-outline" style="width:100%; font-size:.82rem"
                            onclick="document.getElementById('anhFile').click()">
                        <i class="bi bi-folder2-open"></i> Chọn ảnh từ máy
                    </button>

                    <div style="margin-top:8px; font-size:.75rem; color:var(--muted)">
                        Tỉ lệ khuyến nghị: 16:9 (1280×720px)
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body" style="display:flex; flex-direction:column; gap:10px">
                    <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center">
                        <i class="bi bi-check-lg"></i> Lưu khóa học
                    </button>
                    <a asp-action="Index" class="btn btn-outline" style="width:100%; justify-content:center">
                        Hủy bỏ
                    </a>
                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImg(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById('imgPreview').src = e.target.result;
                    document.getElementById('imgPreview').style.display = 'block';
                    document.getElementById('imgPlaceholder').style.display = 'none';
                    document.getElementById('imgPreviewWrap').style.borderStyle = 'solid';
                    document.getElementById('imgPreviewWrap').style.borderColor = 'var(--brand)';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
        function handleDrop(e) {
            e.preventDefault();
            document.getElementById('imgPreviewWrap').style.borderColor = 'var(--border)';
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) {
                const dt = new DataTransfer();
                dt.items.add(file);
                document.getElementById('anhFile').files = dt.files;
                previewImg(document.getElementById('anhFile'));
            }
        }
    </script>
}
