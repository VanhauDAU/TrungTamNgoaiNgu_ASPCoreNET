@model TrungTamNgoaiNgu.Models.KhoaHoc
@{
    ViewData["Title"] = "Sửa khóa học";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">Sửa khóa học</div>
        <div class="page-sub">Đang chỉnh sửa: <strong>@Model.TenKhoaHoc</strong></div>
    </div>
    <div style="display:flex; gap:8px">
        <a asp-action="" class="btn btn-outline">
            <i class="bi bi-trash3"></i> Thùng rác
        </a>
        <a asp-action="Index" class="btn btn-outline">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="KhoaHocId" />
    <input type="hidden" asp-for="AnhKhoaHoc" id="anhHienTai" />

    <div style="display:grid; grid-template-columns:1fr 340px; gap:20px; align-items:start">

        <!-- ── Cột trái ── -->
        <div style="display:flex; flex-direction:column; gap:16px">
            <div class="card">
                <div class="card-header"><i class="bi bi-info-circle"></i> Thông tin cơ bản</div>
                <div class="card-body" style="display:flex; flex-direction:column; gap:14px">

                    <div class="form-group">
                        <label asp-for="TenKhoaHoc">Tên khóa học <span style="color:var(--red)">*</span></label>
                        <input asp-for="TenKhoaHoc" class="form-control" />
                        <span asp-validation-for="TenKhoaHoc" class="text-danger"></span>
                    </div>

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px">
                        <div class="form-group">
                            <label asp-for="DanhMucId">Danh mục</label>
                            <select asp-for="DanhMucId" class="form-control">
                                <option value="">-- Chọn danh mục --</option>
                                @foreach (var dm in (List<TrungTamNgoaiNgu.Models.DanhMucKhoaHoc>)ViewBag.DanhMucs)
                                {
                                    if (Model.DanhMucId == dm.DanhMucId)
                                    {
                                        <option value="@dm.DanhMucId" selected>@dm.TenDanhMuc</option>
                                    }
                                    else
                                    {
                                        <option value="@dm.DanhMucId">@dm.TenDanhMuc</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="form-group">
                            <label asp-for="TrangThai">Trạng thái</label>
                            <select asp-for="TrangThai" class="form-control">
                                @if (Model.TrangThai == 1) { <option value="1" selected>✅ Đang mở</option> }
                                else { <option value="1">✅ Đang mở</option> }
                                @if (Model.TrangThai == 2) { <option value="2" selected>🔜 Sắp khai giảng</option> }
                                else { <option value="2">🔜 Sắp khai giảng</option> }
                                @if (Model.TrangThai == 0) { <option value="0" selected>❌ Đã đóng</option> }
                                else { <option value="0">❌ Đã đóng</option> }
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="MoTa">Mô tả ngắn</label>
                        <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><i class="bi bi-list-check"></i> Chi tiết chương trình</div>
                <div class="card-body" style="display:flex; flex-direction:column; gap:14px">
                    <div class="form-group">
                        <label asp-for="DoiTuong">Đối tượng học viên</label>
                        <input asp-for="DoiTuong" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label asp-for="KetQuaDatDuoc">Kết quả đạt được</label>
                        <textarea asp-for="KetQuaDatDuoc" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label asp-for="YeuCauDauVao">Yêu cầu đầu vào</label>
                        <input asp-for="YeuCauDauVao" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Cột phải: ảnh + nút ── -->
        <div style="display:flex; flex-direction:column; gap:16px">
            <div class="card">
                <div class="card-header"><i class="bi bi-image"></i> Ảnh khóa học</div>
                <div class="card-body">
                    <!-- Preview -->
                    <div id="imgPreviewWrap" onclick="document.getElementById('anhFile').click()"
                         ondragover="event.preventDefault(); this.style.borderColor='var(--brand)'"
                         ondragleave="this.style.borderColor=''"
                         ondrop="handleDrop(event)"
                         style="width:100%; aspect-ratio:16/9; border-radius:10px; overflow:hidden;
                                margin-bottom:12px; display:flex; align-items:center; justify-content:center;
                                background:#f9fafb; cursor:pointer; transition:border-color .2s;
                                @(string.IsNullOrEmpty(Model.AnhKhoaHoc) ? "border:2px dashed var(--border)" : "border:2px solid var(--brand)")">
                        @if (!string.IsNullOrEmpty(Model.AnhKhoaHoc))
                        {
                            <img id="imgPreview" src="@Model.AnhKhoaHoc" alt="Ảnh khóa học"
                                 style="width:100%; height:100%; object-fit:cover;" />
                            <div id="imgPlaceholder" style="display:none"></div>
                        }
                        else
                        {
                            <img id="imgPreview" src="#" style="width:100%; height:100%; object-fit:cover; display:none" />
                            <div id="imgPlaceholder" style="text-align:center; color:var(--muted)">
                                <i class="bi bi-cloud-upload" style="font-size:2.2rem; display:block; margin-bottom:8px; opacity:.5"></i>
                                <div style="font-size:.82rem; font-weight:500">Nhấp hoặc kéo thả ảnh</div>
                                <div style="font-size:.75rem; margin-top:4px">JPG, PNG, WEBP • Tối đa 5MB</div>
                            </div>
                        }
                    </div>

                    <input type="file" id="anhFile" name="anhFile" accept="image/*"
                           style="display:none" onchange="previewImg(this)" />

                    <button type="button" class="btn btn-outline" style="width:100%; font-size:.82rem"
                            onclick="document.getElementById('anhFile').click()">
                        <i class="bi bi-folder2-open"></i>
                        @(string.IsNullOrEmpty(Model.AnhKhoaHoc) ? "Chọn ảnh" : "Đổi ảnh khác")
                    </button>

                    @if (!string.IsNullOrEmpty(Model.AnhKhoaHoc))
                    {
                        <div style="margin-top:8px; font-size:.75rem; color:var(--muted)">
                            Ảnh hiện tại đang được dùng. Upload ảnh mới để thay thế.
                        </div>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-body" style="display:flex; flex-direction:column; gap:10px">
                    <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center">
                        <i class="bi bi-check-lg"></i> Cập nhật khóa học
                    </button>
                    <a asp-action="Index" class="btn btn-outline" style="width:100%; justify-content:center">
                        Hủy bỏ
                    </a>
                </div>
            </div>

            <!-- Meta info -->
            <div class="card">
                <div class="card-body" style="font-size:.78rem; color:var(--muted); display:flex; flex-direction:column; gap:6px">
                    <div>🔑 ID: <strong>#@Model.KhoaHocId</strong></div>
                    <div>📅 Tạo: <strong>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong></div>
                    <div>✏️ Cập nhật: <strong>@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</strong></div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImg(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById('imgPreview').src = e.target.result;
                    document.getElementById('imgPreview').style.display = 'block';
                    document.getElementById('imgPlaceholder').style.display = 'none';
                    document.getElementById('imgPreviewWrap').style.borderStyle = 'solid';
                    document.getElementById('imgPreviewWrap').style.borderColor = 'var(--brand)';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
        function handleDrop(e) {
            e.preventDefault();
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) {
                const dt = new DataTransfer();
                dt.items.add(file);
                document.getElementById('anhFile').files = dt.files;
                previewImg(document.getElementById('anhFile'));
            }
        }
    </script>
}
