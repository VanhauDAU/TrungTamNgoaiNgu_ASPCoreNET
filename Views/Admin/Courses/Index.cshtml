@model List<TrungTamNgoaiNgu.Models.KhoaHoc>
@{
    ViewData["Title"] = "Khóa học";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int pg         = ViewBag.Page ?? 1;
    int pgSize     = ViewBag.PageSize ?? 10;
    int total      = ViewBag.Total ?? Model.Count;
    int totalPages = (int)Math.Ceiling(total / (double)pgSize);
    string tuKhoa     = ViewBag.TuKhoa ?? "";
    string trangThaiQ = ViewBag.TrangThai?.ToString() ?? "";
    string danhMucIdQ = ViewBag.DanhMucId?.ToString() ?? "";
    var stats = ViewBag.Stats as TrungTamNgoaiNgu.Services.Interfaces.KhoaHocQuanLyThongKe
        ?? new TrungTamNgoaiNgu.Services.Interfaces.KhoaHocQuanLyThongKe();
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-courses.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">Quản lý khóa học</div>
        <div class="page-sub">Tổng: <strong>@total</strong> khóa học</div>
    </div>
    <div class="kh-header-actions">
        <a asp-action="Trash" class="btn btn-outline">
            <i class="bi bi-trash3"></i> Thùng rác
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Thêm khóa học
        </a>
    </div>
</div>

<div class="kh-mini-stats">
    <div class="kh-mini-card all">
        <div class="kh-mini-label">Tổng khóa học</div>
        <div class="kh-mini-value">@stats.TongKhoaHoc</div>
    </div>
    <div class="kh-mini-card open">
        <div class="kh-mini-label">Khóa học hoạt động</div>
        <div class="kh-mini-value">@stats.DangHoatDong</div>
    </div>
    <div class="kh-mini-card closed">
        <div class="kh-mini-label">Khóa học tạm ngưng</div>
        <div class="kh-mini-value">@stats.TamNgung</div>
    </div>
    <div class="kh-mini-card open">
        <div class="kh-mini-label">Lớp đang mở/đang học</div>
        <div class="kh-mini-value">@stats.LopDangMo</div>
    </div>
    <div class="kh-mini-card soon">
        <div class="kh-mini-label">Lớp sắp khai giảng</div>
        <div class="kh-mini-value">@stats.LopSapKhaiGiang</div>
    </div>
    <div class="kh-mini-card deleted">
        <div class="kh-mini-label">Đã xóa mềm</div>
        <div class="kh-mini-value">@stats.DaXoaMem</div>
    </div>
</div>

<!-- BỘ LỌC -->
<div class="card kh-filter-card">
    <div class="card-body kh-filter-body">
        <form method="get" class="kh-filter-form">
            <div class="search-wrap kh-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" name="tuKhoa" value="@tuKhoa" class="form-control"
                       placeholder="Tìm tên khóa học..." />
            </div>

            <select name="danhMucId" class="form-control kh-select-danhmuc">
                <option value="">Tất cả danh mục</option>
                @foreach (var dm in (List<TrungTamNgoaiNgu.Models.DanhMucKhoaHoc>)ViewBag.DanhMucs)
                {
                    if (danhMucIdQ == dm.DanhMucId.ToString())
                    {
                        <option value="@dm.DanhMucId" selected>@dm.TenDanhMuc</option>
                    }
                    else
                    {
                        <option value="@dm.DanhMucId">@dm.TenDanhMuc</option>
                    }
                }
            </select>

            <select name="trangThai" class="form-control kh-select-trangthai">
                <option value="">Tất cả trạng thái</option>
                @if (trangThaiQ == "1") { <option value="1" selected>✅ Đang hoạt động</option> }
                else { <option value="1">✅ Đang hoạt động</option> }
                @if (trangThaiQ == "0") { <option value="0" selected>⏸ Tạm ngưng</option> }
                else { <option value="0">⏸ Tạm ngưng</option> }
            </select>

            <select name="pageSize" class="form-control kh-select-pagesize">
                @if (pgSize == 10) { <option value="10" selected>10 dòng/trang</option> }
                else { <option value="10">10 dòng/trang</option> }
                @if (pgSize == 20) { <option value="20" selected>20 dòng/trang</option> }
                else { <option value="20">20 dòng/trang</option> }
                @if (pgSize == 50) { <option value="50" selected>50 dòng/trang</option> }
                else { <option value="50">50 dòng/trang</option> }
            </select>

            <button type="submit" class="btn btn-primary"><i class="bi bi-funnel-fill"></i> Lọc</button>
            @if (!string.IsNullOrEmpty(tuKhoa) || !string.IsNullOrEmpty(danhMucIdQ) || !string.IsNullOrEmpty(trangThaiQ))
            {
                <a asp-action="Index" class="btn btn-outline"><i class="bi bi-x-circle"></i> Xóa lọc</a>
            }
        </form>
    </div>
</div>

<!-- BẢNG -->
<div class="card">
    <div class="table-wrap">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-journal-x"></i>
                <p>Không tìm thấy khóa học nào</p>
            </div>
        }
        else
        {
            <div class="kh-bulk-row">
                <form id="bulkForm" method="post" asp-action="bulk" class="kh-bulk-controls"
                      onsubmit="return confirmBulkAction()">
                    @Html.AntiForgeryToken()
                    <select id="bulkAction" name="bulkAction" class="form-control kh-bulk-action">
                        <option value="">-- Chọn hành động --</option>
                        <option value="change-status">Đổi trạng thái</option>
                        <option value="soft-delete">Chuyển vào thùng rác</option>
                    </select>
                    <select id="bulkTrangThai" name="bulkTrangThai" class="form-control kh-bulk-status kh-hidden">
                        <option value="">-- Chọn trạng thái --</option>
                        <option value="1">Đang hoạt động</option>
                        <option value="0">Tạm ngưng</option>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm kh-bulk-submit">Áp dụng</button>
                </form>
                <div id="selectedCount" class="kh-selected-count">Đã chọn: 0</div>
            </div>

            <table>
                <thead>
                    <tr>
                        <th class="kh-check-col">
                            <input id="checkAll" type="checkbox" class="kh-check" />
                        </th>
                        <th>#</th>
                        <th>Ảnh</th>
                        <th>Tên khóa học</th>
                        <th>Danh mục</th>
                        <th>Số lớp</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var kh = Model[i];
                        <tr>
                            <td class="kh-check-col">
                                <input type="checkbox" name="selectedIds" value="@kh.KhoaHocId"
                                       class="kh-check kh-select-item" form="bulkForm" />
                            </td>
                            <td class="kh-col-index">@((pg-1)*pgSize + i + 1)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(kh.AnhKhoaHoc))
                                {
                                    <img src="@kh.AnhKhoaHoc" alt="@kh.TenKhoaHoc" class="kh-thumb" />
                                }
                                else
                                {
                                    <div class="kh-thumb-empty">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="kh-name">@kh.TenKhoaHoc</div>
                                <div class="kh-slug">@kh.Slug</div>
                            </td>
                            <td>
                                @if (kh.DanhMuc != null)
                                { <span class="badge badge-indigo">@kh.DanhMuc.TenDanhMuc</span> }
                                else { <span class="kh-muted">—</span> }
                            </td>
                            <td>
                                <span class="badge badge-gray">@(kh.LopHocs?.Count ?? 0) lớp</span>
                            </td>
                            <td>
                                @if (kh.TrangThai == 0)
                                { <span class="badge badge-warning">Tạm ngưng</span> }
                                else
                                { <span class="badge badge-success">Đang hoạt động</span> }
                            </td>
                            <td class="kh-created">
                                @kh.CreatedAt.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                <div class="kh-actions">
                                    <a asp-action="Detail" asp-route-id="@kh.KhoaHocId"
                                       class="btn btn-outline btn-sm" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@kh.KhoaHocId"
                                       class="btn btn-outline btn-sm" title="Chỉnh sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" asp-action="softdelete" asp-route-id="@kh.KhoaHocId"
                                          onsubmit="return confirm('Chuyển &laquo;@kh.TenKhoaHoc&raquo; vào thùng rác?')"
                                          class="kh-inline-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm" title="Xóa mềm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (totalPages > 1)
            {
                <div class="kh-pagination-wrap">
                    <div class="kh-pagination-info">
                        Trang <strong>@pg</strong> / @totalPages &nbsp;·&nbsp; @total mục
                    </div>
                    <div class="kh-pagination-actions">
                        @if (pg > 1)
                        {
                            <a href="?page=@(pg-1)&tuKhoa=@tuKhoa&danhMucId=@danhMucIdQ&trangThai=@trangThaiQ&pageSize=@pgSize"
                               class="btn btn-outline btn-sm"><i class="bi bi-chevron-left"></i></a>
                        }
                        @for (int p = Math.Max(1, pg - 2); p <= Math.Min(totalPages, pg + 2); p++)
                        {
                            if (p == pg)
                            {
                                <a href="?page=@p&tuKhoa=@tuKhoa&danhMucId=@danhMucIdQ&trangThai=@trangThaiQ&pageSize=@pgSize"
                                   class="btn btn-sm btn-primary">@p</a>
                            }
                            else
                            {
                                <a href="?page=@p&tuKhoa=@tuKhoa&danhMucId=@danhMucIdQ&trangThai=@trangThaiQ&pageSize=@pgSize"
                                   class="btn btn-sm btn-outline">@p</a>
                            }
                        }
                        @if (pg < totalPages)
                        {
                            <a href="?page=@(pg+1)&tuKhoa=@tuKhoa&danhMucId=@danhMucIdQ&trangThai=@trangThaiQ&pageSize=@pgSize"
                               class="btn btn-outline btn-sm"><i class="bi bi-chevron-right"></i></a>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        const checkAll = document.getElementById('checkAll');
        const items = Array.from(document.querySelectorAll('.kh-select-item'));
        const selectedCount = document.getElementById('selectedCount');
        const bulkAction = document.getElementById('bulkAction');
        const bulkTrangThai = document.getElementById('bulkTrangThai');

        function updateSelectedCount() {
            if (!selectedCount) return;
            const count = items.filter(x => x.checked).length;
            selectedCount.textContent = `Đã chọn: ${count}`;
            if (checkAll) {
                checkAll.checked = count > 0 && count === items.length;
                checkAll.indeterminate = count > 0 && count < items.length;
            }
        }

        if (checkAll) {
            checkAll.addEventListener('change', () => {
                items.forEach(x => x.checked = checkAll.checked);
                updateSelectedCount();
            });
        }
        items.forEach(x => x.addEventListener('change', updateSelectedCount));
        updateSelectedCount();

        if (bulkAction) {
            bulkAction.addEventListener('change', () => {
                if (bulkAction.value === 'change-status') {
                    bulkTrangThai.classList.remove('kh-hidden');
                } else {
                    bulkTrangThai.classList.add('kh-hidden');
                    bulkTrangThai.value = '';
                }
            });
        }

        function confirmBulkAction() {
            if (!selectedCount) return false;
            const count = items.filter(x => x.checked).length;
            if (count === 0) {
                alert('Vui lòng chọn ít nhất một khóa học.');
                return false;
            }

            const action = bulkAction.value;
            if (!action) {
                alert('Vui lòng chọn hành động.');
                return false;
            }
            if (action === 'change-status' && !bulkTrangThai.value) {
                alert('Vui lòng chọn trạng thái cần cập nhật.');
                return false;
            }

            return confirm(`Xác nhận áp dụng hành động cho ${count} khóa học đã chọn?`);
        }
    </script>
}
