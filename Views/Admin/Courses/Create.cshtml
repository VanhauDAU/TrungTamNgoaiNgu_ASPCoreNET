@model TrungTamNgoaiNgu.Models.KhoaHoc
@{
    ViewData["Title"] = "Thêm khóa học";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-courses.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <div class="page-title">Thêm khóa học mới</div>
        <div class="page-sub">Điền đầy đủ thông tin bên dưới rồi nhấn Lưu</div>
    </div>
    <a asp-action="Index" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<form id="khoaHocForm" asp-action="Create" method="post" enctype="multipart/form-data" data-draft-key="khoahoc-create">
    @Html.AntiForgeryToken()
    <div id="draftNotice" class="kh-draft-note kh-hidden">
        <span>Đã khôi phục bản nháp tự động cho form này.</span>
        <button type="button" id="clearDraftBtn">Xóa nháp</button>
    </div>
    <div class="kh-form-grid">

        <!-- ── Cột trái: thông tin ── -->
        <div class="kh-col-left">

            <div class="card">
                <div class="card-header"><i class="bi bi-info-circle"></i> Thông tin cơ bản</div>
                <div class="card-body kh-stack-14">

                    <div class="form-group">
                        <label asp-for="TenKhoaHoc">Tên khóa học <span class="kh-required">*</span></label>
                        <input asp-for="TenKhoaHoc" class="form-control" placeholder="VD: IELTS Intensive 7.0+" />
                        <span asp-validation-for="TenKhoaHoc" class="text-danger"></span>
                    </div>

                    <div class="kh-two-col">
                        <div class="form-group">
                            <label asp-for="DanhMucId">Danh mục <span class="kh-required">*</span></label>
                            <select asp-for="DanhMucId" class="form-control">
                                <option value="">-- Chọn danh mục --</option>
                                @foreach (var dm in (List<TrungTamNgoaiNgu.Models.DanhMucKhoaHoc>)ViewBag.DanhMucs)
                                {
                                    <option value="@dm.DanhMucId">@dm.TenDanhMuc</option>
                                }
                            </select>
                            <span asp-validation-for="DanhMucId" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="TrangThai">Trạng thái</label>
                            <select asp-for="TrangThai" class="form-control">
                                <option value="1">✅ Đang hoạt động</option>
                                <option value="0">⏸ Tạm ngưng</option>
                            </select>
                            <span asp-validation-for="TrangThai" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="MoTa">Mô tả ngắn</label>
                        <textarea asp-for="MoTa" class="form-control" rows="3"
                                  placeholder="Giới thiệu ngắn về khóa học..."></textarea>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><i class="bi bi-list-check"></i> Chi tiết chương trình</div>
                <div class="card-body kh-stack-14">
                    <div class="form-group">
                        <label asp-for="DoiTuong">Đối tượng học viên</label>
                        <input asp-for="DoiTuong" class="form-control"
                               placeholder="VD: Học sinh cấp 3, người đi làm muốn lấy chứng chỉ..." />
                    </div>
                    <div class="form-group">
                        <label asp-for="KetQuaDatDuoc">Kết quả đạt được</label>
                        <textarea asp-for="KetQuaDatDuoc" class="form-control" rows="3"
                                  placeholder="Sau khi hoàn thành, học viên sẽ..."></textarea>
                    </div>
                    <div class="form-group">
                        <label asp-for="YeuCauDauVao">Yêu cầu đầu vào</label>
                        <input asp-for="YeuCauDauVao" class="form-control"
                               placeholder="VD: Tiếng Anh cơ bản B1, đã thi thử IELTS..." />
                    </div>
                </div>
            </div>

        </div>

        <!-- ── Cột phải: ảnh + nút lưu ── -->
        <div class="kh-col-right">

            <div class="card">
                <div class="card-header"><i class="bi bi-image"></i> Ảnh khóa học</div>
                <div class="card-body">
                    <!-- Preview -->
                    <div id="imgPreviewWrap" class="kh-dropzone"
                         onclick="document.getElementById('anhFile').click()"
                         ondragover="event.preventDefault(); this.style.borderColor='var(--brand)'"
                         ondragleave="this.style.borderColor='var(--border)'"
                         ondrop="handleDrop(event)">
                        <img id="imgPreview" src="#" alt="preview" class="kh-drop-preview" />
                        <div id="imgPlaceholder" class="kh-placeholder">
                            <i class="bi bi-cloud-upload kh-placeholder-icon"></i>
                            <div class="kh-placeholder-title">Nhấp hoặc kéo thả ảnh vào đây</div>
                            <div class="kh-placeholder-sub">JPG, PNG, WEBP • Tối đa 5MB</div>
                        </div>
                    </div>

                    <input type="file" id="anhFile" name="anhFile" accept="image/*"
                           class="kh-file-input" onchange="previewImg(this)" />
                    <span asp-validation-for="AnhKhoaHoc" class="text-danger"></span>

                    <button type="button" class="btn btn-outline kh-pick-btn"
                            onclick="document.getElementById('anhFile').click()">
                        <i class="bi bi-folder2-open"></i> Chọn ảnh từ máy
                    </button>

                    <div class="kh-help-text">
                        Tỉ lệ khuyến nghị: 16:9 (1280×720px)
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body kh-stack-10">
                    <button type="submit" class="btn btn-primary kh-full-btn">
                        <i class="bi bi-check-lg"></i> Lưu khóa học
                    </button>
                    <a asp-action="Index" class="btn btn-outline kh-full-btn">
                        Hủy bỏ
                    </a>
                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const form = document.getElementById('khoaHocForm');
        const draftNotice = document.getElementById('draftNotice');
        const clearDraftBtn = document.getElementById('clearDraftBtn');
        const draftKey = `draft:${form.dataset.draftKey}`;
        const trackFields = Array.from(form.querySelectorAll('input, textarea, select'))
            .filter(el =>
                el.name &&
                el.type !== 'hidden' &&
                el.type !== 'file' &&
                el.name !== '__RequestVerificationToken');
        const fileInput = document.getElementById('anhFile');
        const imgPreview = document.getElementById('imgPreview');
        const imgPlaceholder = document.getElementById('imgPlaceholder');
        const imgPreviewWrap = document.getElementById('imgPreviewWrap');
        let isDirty = false;
        let isSubmitting = false;
        let saveTimer = null;

        function collectDraft() {
            const payload = {};
            trackFields.forEach(el => payload[el.name] = el.value);
            return payload;
        }

        function saveDraft() {
            clearTimeout(saveTimer);
            saveTimer = setTimeout(() => {
                localStorage.setItem(draftKey, JSON.stringify(collectDraft()));
            }, 250);
        }

        function restoreDraft() {
            const raw = localStorage.getItem(draftKey);
            if (!raw) return;

            try {
                const data = JSON.parse(raw);
                trackFields.forEach(el => {
                    if (Object.prototype.hasOwnProperty.call(data, el.name) && !el.value) {
                        el.value = data[el.name];
                    }
                });
                draftNotice.classList.remove('kh-hidden');
                isDirty = true;
            } catch {
                localStorage.removeItem(draftKey);
            }
        }

        trackFields.forEach(el => {
            el.addEventListener('input', () => { isDirty = true; saveDraft(); });
            el.addEventListener('change', () => { isDirty = true; saveDraft(); });
        });

        clearDraftBtn.addEventListener('click', () => {
            clearTimeout(saveTimer);
            localStorage.removeItem(draftKey);
            localStorage.removeItem(form.dataset.draftKey);
            form.reset();
            if (fileInput) fileInput.value = '';
            if (imgPreview) {
                imgPreview.src = '#';
                imgPreview.classList.remove('show');
            }
            if (imgPlaceholder) imgPlaceholder.style.display = '';
            if (imgPreviewWrap) {
                imgPreviewWrap.classList.remove('has-image');
                imgPreviewWrap.style.borderColor = 'var(--border)';
            }
            isDirty = false;
            draftNotice.classList.add('kh-hidden');
        });

        form.addEventListener('submit', () => {
            isSubmitting = true;
            localStorage.removeItem(draftKey);
        });

        window.addEventListener('beforeunload', e => {
            if (isDirty && !isSubmitting) {
                e.preventDefault();
                e.returnValue = '';
            }
        });

        restoreDraft();

        function previewImg(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById('imgPreview').src = e.target.result;
                    document.getElementById('imgPreview').classList.add('show');
                    document.getElementById('imgPlaceholder').style.display = 'none';
                    document.getElementById('imgPreviewWrap').classList.add('has-image');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
        function handleDrop(e) {
            e.preventDefault();
            document.getElementById('imgPreviewWrap').style.borderColor = 'var(--border)';
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) {
                const dt = new DataTransfer();
                dt.items.add(file);
                document.getElementById('anhFile').files = dt.files;
                previewImg(document.getElementById('anhFile'));
            }
        }
    </script>
}
