@model TrungTamNgoaiNgu.Models.KhoaHoc
@{
    ViewData["Title"] = "Thêm khóa học";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">Thêm khóa học mới</div>
        <div class="page-subtitle">Điền đầy đủ thông tin bên dưới rồi nhấn Lưu</div>
    </div>
    <a asp-action="Index" class="btn btn-outline">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<div style="max-width:720px">
    <div class="card">
        <div class="card-header">
            <span><i class="bi bi-journal-plus"></i> Thông tin khóa học</span>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px">
                    <div class="form-group" style="grid-column:1/-1">
                        <label asp-for="TenKhoaHoc">Tên khóa học <span style="color:var(--danger)">*</span></label>
                        <input asp-for="TenKhoaHoc" class="form-control" placeholder="VD: IELTS Intensive 7.0+" />
                        <span asp-validation-for="TenKhoaHoc" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="DanhMucId">Danh mục <span style="color:var(--danger)">*</span></label>
                        <select asp-for="DanhMucId" class="form-control">
                            <option value="">-- Chọn danh mục --</option>
                            @foreach (var dm in (List<TrungTamNgoaiNgu.Models.DanhMucKhoaHoc>)ViewBag.DanhMucs)
                            {
                                <option value="@dm.DanhMucId">@dm.TenDanhMuc</option>
                            }
                        </select>
                        <span asp-validation-for="DanhMucId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="TrangThai">Trạng thái</label>
                        <select asp-for="TrangThai" class="form-control">
                            <option value="1">✅ Đang mở</option>
                            <option value="2">🔜 Sắp khai giảng</option>
                            <option value="0">❌ Đã đóng</option>
                        </select>
                    </div>

                    <div class="form-group" style="grid-column:1/-1">
                        <label asp-for="MoTa">Mô tả ngắn</label>
                        <textarea asp-for="MoTa" class="form-control" rows="3"
                                  placeholder="Giới thiệu ngắn về khóa học..."></textarea>
                    </div>

                    <div class="form-group" style="grid-column:1/-1">
                        <label asp-for="DoiTuong">Đối tượng học viên</label>
                        <input asp-for="DoiTuong" class="form-control"
                               placeholder="VD: Học sinh cấp 3, người đi làm muốn lấy chứng chỉ..." />
                    </div>

                    <div class="form-group" style="grid-column:1/-1">
                        <label asp-for="KetQuaDatDuoc">Kết quả đạt được</label>
                        <textarea asp-for="KetQuaDatDuoc" class="form-control" rows="3"
                                  placeholder="Sau khi hoàn thành khóa học, học viên sẽ..."></textarea>
                    </div>

                    <div class="form-group" style="grid-column:1/-1">
                        <label asp-for="YeuCauDauVao">Yêu cầu đầu vào</label>
                        <input asp-for="YeuCauDauVao" class="form-control"
                               placeholder="VD: Tiếng Anh cơ bản B1, đã thi thử IELTS..." />
                    </div>
                </div>

                <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:8px">
                    <a asp-action="Index" class="btn btn-outline">Hủy</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Lưu khóa học
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
